{
  "manifest_version": 3,
  "name": "Beyond Continue",
  "version": "2.1.1",
  "description": "Self-improving MQL4/MQL5 development environment with AI learning",
  "permissions": ["storage", "activeTab"],
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.google.com/*", "*://claude.ai/*"],
      "js": ["content/content.js"]
    }
  ],
  "action": {
    "default_title": "Beyond Continue",
    "default_popup": "popup.html"
  }
}